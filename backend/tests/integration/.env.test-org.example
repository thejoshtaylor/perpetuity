# M004-guylpp / S07 / T01 — manual UAT credentials template.
#
# The four real-GitHub acceptance scenarios in
# `test_m004_guylpp_s07_full_acceptance_e2e.py` are skipped by default.
# To run them against a real GitHub test org:
#
#   1. Copy this file to `.env.test-org` (gitignored — never commit secrets).
#   2. Fill in every value below from a dedicated GitHub test org you own.
#   3. Export the values and set `RUN_REAL_GITHUB=1`:
#
#        set -a; source backend/tests/integration/.env.test-org; set +a
#        export RUN_REAL_GITHUB=1
#        cd backend && POSTGRES_PORT=5432 uv run pytest -m e2e -p no:cacheprovider \
#            tests/integration/test_m004_guylpp_s07_full_acceptance_e2e.py -v
#
# Wall-clock budget for scenarios 1-4 combined: ≤5 minutes.
# Do NOT paste private-key bodies into shell history — use a filesystem path.

# Org slug or user login that owns the test repo + has the GitHub App installed.
GITHUB_TEST_ORG=

# Full name of the test repo. Must be a real repo in GITHUB_TEST_ORG that the
# installed GitHub App has read+write access to. Format: "owner/repo".
GITHUB_TEST_REPO_FULL_NAME=

# GitHub App identifiers (from https://github.com/settings/apps/<your-app>).
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=

# Filesystem path to the App's private key PEM. Keep the PEM body OUT of env;
# the test reads the file when it needs to mint a JWT. The file must exist and
# be readable; mode 0600 is recommended.
GITHUB_APP_PRIVATE_KEY_PATH=

# Personal access token for a user account that can push to GITHUB_TEST_REPO_FULL_NAME.
# Used to trigger the external push in scenario 2 (webhook round-trip). Must
# have `repo` scope. Treat as sensitive.
GITHUB_TEST_USER_PAT=

# Base URLs for the locally-running stack the operator is exercising.
# Defaults match `docker compose up -d` with the standard port publishing.
BACKEND_BASE_URL=http://localhost:8080
ORCHESTRATOR_BASE_URL=http://localhost:8081
